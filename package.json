{
  "name": "ene-desktop",
  "version": "0.1.0",
  "description": "Desktop Character Agent (コードネーム: ENE) — 一生付き合える、人格を持ったデスクトップの相棒",
  "private": true,
  "main": "out/main/index.js",
  "author": "ENE Project",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "package:portable": "electron-vite build && electron-builder --win portable",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "download:model": "node scripts/download-model.mjs",
    "download:stt-model": "node scripts/download-stt-model.mjs",
    "download:vad-model": "node scripts/download-vad-model.mjs",
    "seed:recall": "node scripts/seed-recall-fixtures.mjs",
    "voice:smoke": "node scripts/voice-smoke.mjs",
    "stt:smoke": "node scripts/stt-smoke.mjs",
    "vad:smoke": "node scripts/vad-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@huggingface/transformers": "^4.2.0",
    "electron-log": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^1.6.0"
  }
}
